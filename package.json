{
  "name": "claude-orchestrator",
  "version": "0.1.11",
  "description": "Desktop Kanban board for managing Claude Code CLI sessions",
  "author": "Marco Bornman <marco.bornman@nurtur.tech>",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "node scripts/patch-node-pty.js && electron-builder install-app-deps",
    "rebuild": "node scripts/patch-node-pty.js && electron-builder install-app-deps",
    "package:win": "npm run build && electron-builder --win --config electron-builder.yml",
    "release:win": "npm run build && electron-builder --win --publish always --config electron-builder.yml",
    "publish:win": "electron-builder --win --publish always --config electron-builder.yml"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "electron-updater": "^6.8.3",
    "marked": "^18.0.4",
    "node-pty": "^1.0.0",
    "recharts": "^3.8.1",
    "uuid": "^11.1.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.7",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.0",
    "electron-vite": "^3.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3",
    "vite": "^6.3.4"
  }
}
